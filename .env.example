# Banco de Dados
DB_HOST=db
DB_PORT=3306
DB_NAME=salve_alimento
DB_USER=app_user
DB_PASS=sua_senha_aqui
DB_ROOT_PASS=senha_root_aqui

# JWT (gerado com: openssl rand -base64 64)
JWT_SECRET=
JWT_ISSUER=salve-alimento
JWT_EXPIRY=1800

# Chaves RSA (geradas com keys/gerar-chaves.sh)
RSA_PRIVATE_KEY_PATH=/var/www/html/keys/private.pem
RSA_PUBLIC_KEY_PATH=/var/www/html/keys/public.pem

# E-mail (SMTP)
MAIL_HOST=smtp.exemplo.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@salvealimento.com
MAIL_FROM_NAME=Salve Alimento

# Aplicação
APP_ENV=development
APP_URL=http://localhost:8080
APP_DEBUG=false
