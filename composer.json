{
    "name": "salve-alimento/app",
    "description": "Plataforma segura de doação de alimentos — PUCPR Segurança Web",
    "type": "project",
    "require": {
        "php": "^8.2",
        "firebase/php-jwt": "^6.10",
        "guzzlehttp/guzzle": "^7.9",
        "phpmailer/phpmailer": "^6.9",
        "spomky-labs/otphp": "^11.3",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.10",
        "pheromone/phpcs-security-audit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "SalveAlimento\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SalveAlimento\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --testdox tests/",
        "cs": "vendor/bin/phpcs --standard=Security src/"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "audit": {
            "ignore": {
                "PKSA-y2cr-5h3j-g3ys": "Vulnerabilidade conhecida em firebase/php-jwt 6.x — sem patch upstream disponível. Mitigação: validação de JWT é feita via JWKS do Cognito com verificação de assinatura RS256; tokens não são gerados localmente pela biblioteca."
            }
        }
    }
}
